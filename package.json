{
  "name": "mcp-carrefour-drive",
  "version": "0.2.0",
  "description": "MCP server for Carrefour Drive — Search products, manage cart, and order groceries via AI assistants using the Model Context Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-carrefour-drive": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:e2e": "DISPLAY=:0 vitest run tests/e2e.test.ts",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Darkmyter/mcp-carrefour-drive.git"
  },
  "homepage": "https://github.com/Darkmyter/mcp-carrefour-drive#readme",
  "bugs": {
    "url": "https://github.com/Darkmyter/mcp-carrefour-drive/issues"
  },
  "keywords": [
    "mcp",
    "carrefour",
    "drive",
    "grocery",
    "playwright",
    "model-context-protocol",
    "ai-assistant",
    "shopping"
  ],
  "author": "Maxime Allanic (original), Bader (fork)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "playwright": "^1.50.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
